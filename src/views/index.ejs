<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <div class="container">
    <header class="hero">
      <p class="eyebrow">Task Manager REST API</p>
      <h1>Test Your API in the Browser</h1>
      <p class="subtext">Register, login, create tasks, list your tasks, and delete tasks using the same API endpoints from your assignment.</p>
    </header>

    <section class="grid">
      <article class="card">
        <h2>Create Account</h2>
        <form id="registerForm" class="form">
          <input type="text" id="registerName" placeholder="Full name" required />
          <input type="email" id="registerEmail" placeholder="Email" required />
          <input type="password" id="registerPassword" placeholder="Password (min 6 chars)" required minlength="6" />
          <button type="submit">Register</button>
        </form>
      </article>

      <article class="card">
        <h2>Login</h2>
        <form id="loginForm" class="form">
          <input type="email" id="loginEmail" placeholder="Email" required />
          <input type="password" id="loginPassword" placeholder="Password" required />
          <button type="submit">Login</button>
        </form>

        <div class="token-box">
          <label for="tokenInput">JWT Token</label>
          <textarea id="tokenInput" rows="4" placeholder="Token appears here after login"></textarea>
          <button id="saveTokenButton" class="secondary" type="button">Use Token</button>
          <button id="logoutButton" class="danger" type="button">Clear Token</button>
        </div>
      </article>
    </section>

    <section class="card">
      <h2>Create Task</h2>
      <form id="taskForm" class="form-row">
        <input type="text" id="taskTitle" placeholder="Task title" required />
        <input type="text" id="taskDescription" placeholder="Task description" />
        <button type="submit">Add Task</button>
      </form>
    </section>

    <section class="card">
      <div class="tasks-header">
        <h2>Your Tasks</h2>
        <button id="refreshTasksButton" class="secondary" type="button">Refresh</button>
      </div>
      <ul id="taskList" class="task-list"></ul>
    </section>

    <p id="statusMessage" class="status">Ready.</p>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
