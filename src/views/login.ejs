<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <div class="container narrow">
    <header class="hero">
      <p class="eyebrow">Task Manager REST API</p>
      <h1>Login / Register</h1>
      <p class="subtext">Authenticate to start managing your tasks from the browser UI.</p>
    </header>

    <section class="grid">
      <article class="card">
        <h2>Create Account</h2>
        <form id="registerForm" class="form">
          <input type="text" id="registerName" placeholder="Full name" required />
          <input type="email" id="registerEmail" placeholder="Email" required />
          <input type="password" id="registerPassword" placeholder="Password (min 6 chars)" required minlength="6" />
          <button type="submit">Register</button>
        </form>
      </article>

      <article class="card">
        <h2>Sign In</h2>
        <form id="loginForm" class="form">
          <input type="email" id="loginEmail" placeholder="Email" required />
          <input type="password" id="loginPassword" placeholder="Password" required />
          <button type="submit">Login</button>
        </form>
      </article>
    </section>

    <p id="statusMessage" class="status">Ready.</p>
  </div>

  <script src="/js/login.js"></script>
</body>
</html>
